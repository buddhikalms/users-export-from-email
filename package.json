{
  "name": "omazync",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "test": "node --test tests/*.test.ts",
    "worker:email-sync": "tsx workers/email-sync-worker.ts",
    "test:security": "node --test tests/vault-security.test.ts",
    "load:smoke": "k6 run load-tests/smoke-test.js",
    "load:dashboard": "k6 run load-tests/dashboard-load-test.js",
    "load:sync": "k6 run load-tests/api-sync-test.js",
    "load:export": "k6 run load-tests/export-load-test.js",
    "typecheck": "tsc --noEmit",
    "db:start": "docker compose up -d mysql",
    "redis:start": "docker compose up -d redis",
    "redis:check": "node -e \"const net=require('node:net');const s=net.createConnection({host:'127.0.0.1',port:6379});s.on('connect',()=>{console.log('Redis reachable on 127.0.0.1:6379');s.end();});s.on('error',()=>{console.error('Redis is not reachable on 127.0.0.1:6379');process.exit(1);});\"",
    "services:start": "docker compose up -d mysql redis",
    "db:stop": "docker compose stop mysql",
    "redis:stop": "docker compose stop redis",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:init": "node scripts/init-db.mjs"
  },
  "dependencies": {
    "@ioredis/commands": "^1.5.1",
    "@prisma/client": "^6.17.1",
    "@radix-ui/react-checkbox": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@tanstack/react-table": "^8.21.3",
    "axios": "^1.16.1",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.79.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cluster-key-slot": "^1.1.2",
    "denque": "^2.1.0",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.40.0",
    "imapflow": "^1.0.181",
    "ioredis": "^5.11.1",
    "lodash.defaults": "^4.2.0",
    "lodash.isarguments": "^3.1.0",
    "lucide-react": "^0.511.0",
    "next": "^16.2.4",
    "next-auth": "^4.24.14",
    "prisma": "^6.17.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "redis-errors": "^1.2.0",
    "redis-parser": "^3.0.0",
    "tailwind-merge": "^2.5.4",
    "tsx": "^4.23.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
