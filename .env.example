NEXT_PUBLIC_APP_NAME=Outlook Sync Exporter
IMAP_CONNECT_TIMEOUT_MS=20000
IMAP_SOCKET_TIMEOUT_MS=45000
DATABASE_URL="mysql://outlook_user:outlook_password@127.0.0.1:3306/outlook_sync_exporter"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
ACCOUNT_ENCRYPTION_KEY="replace-with-a-long-random-encryption-key"

# Production note:
# If you later add encrypted credential storage, place the encryption key here
# and only decrypt credentials on the server side.
