NEXT_PUBLIC_APP_NAME=BuddhiEmailExtractor
IMAP_CONNECT_TIMEOUT_MS=20000
IMAP_SOCKET_TIMEOUT_MS=45000
DATABASE_URL="mysql://buddhi_user:buddhi_password@127.0.0.1:3306/buddhi_email_extractor"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
