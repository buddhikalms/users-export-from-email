NEXT_PUBLIC_APP_NAME=BuddhiEmailExtractor
IMAP_CONNECT_TIMEOUT_MS=20000
IMAP_SOCKET_TIMEOUT_MS=45000
DATABASE_URL="mysql://buddhi_user:buddhi_password@127.0.0.1:3306/buddhi_email_extractor"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ACCOUNT_ENCRYPTION_KEY="replace-with-a-long-random-encryption-key"
KIT_API_KEY=
KIT_API_SECRET=

# Google Sheets export:
# Create a Google Cloud service account, enable Google Sheets API and Google Drive API,
# then paste the service account email and private key here.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-with-service-account-private-key\n-----END PRIVATE KEY-----\n"
# Alternative for hosts that do not preserve multiline env values:
# GOOGLE_PRIVATE_KEY_BASE64=

# Production note:
# Saved email and marketing platform credentials are encrypted with ACCOUNT_ENCRYPTION_KEY
# and only decrypted for server-side API calls.
