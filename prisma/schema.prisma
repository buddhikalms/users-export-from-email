generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum SecurityType {
  ssl_tls
  starttls
}

enum KitApiVersion {
  v4
  v3
}

enum ContactStatus {
  NEW
  QUALIFIED
  NURTURING
  CUSTOMER
  UNSUBSCRIBED
  BOUNCED
  ARCHIVED
}

enum ContactSourceType {
  DIRECT_EMAIL
  FORWARDED_EMAIL
  ORIGINAL_SENDER
  REPLY_TO
  MANUAL_IMPORT
  API_IMPORT
}

enum EmailClassification {
  BUSINESS
  PERSONAL
  ROLE_BASED
  DISPOSABLE
  UNKNOWN
}

enum MarketingPlatform {
  KIT
  MAILCHIMP
  BREVO
  BEEHIIV
  ACTIVECAMPAIGN
  CONVERTKIT_LEGACY
  HUBSPOT
  MAILERLITE
  CONSTANT_CONTACT
  SENDGRID_MARKETING
  CAMPAIGN_MONITOR
  ZOHO_CAMPAIGNS
}

enum IntegrationHealth {
  UNKNOWN
  HEALTHY
  DEGRADED
  FAILED
}

enum SyncStatus {
  QUEUED
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
  CANCELLED
}

enum ExportFormat {
  EXCEL
  CSV
  JSON
  GOOGLE_SHEETS
}

enum AutomationTrigger {
  SCHEDULED
  FOLDER_SYNCED
  CONTACT_CREATED
  TAG_MATCHED
  MANUAL
}

enum JobType {
  MAILBOX_SYNC
  CONTACT_CLEANUP
  PLATFORM_SYNC
  FILE_EXPORT
  AUTOMATION_RUN
  AI_ENRICHMENT
}

enum JobStatus {
  QUEUED
  RUNNING
  RETRYING
  COMPLETED
  FAILED
  CANCELLED
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum BillingPlan {
  FREE
  STARTER
  PROFESSIONAL
  BUSINESS
  ENTERPRISE
}

enum BillingInterval {
  MONTHLY
  YEARLY
  CUSTOM
}

enum SubscriptionStatus {
  FREE
  APPROVAL_PENDING
  ACTIVE
  SUSPENDED
  CANCELLED
  EXPIRED
}

model User {
  id                  String               @id @default(cuid())
  name                String
  email               String               @unique
  passwordHash        String
  role                UserRole             @default(USER)
  savedAccounts       SavedEmailAccount[]
  ignoredEmails       IgnoredEmail[]
  kitSettings         KitSettings?
  kitAccounts         KitAccount[]
  encryptedVaults     EncryptedVault[]
  memberships         OrganizationMember[]
  ownedOrganizations  Organization[]       @relation("OrganizationOwner")
  contacts            Contact[]
  integrationAccounts IntegrationAccount[]
  automationRules     AutomationRule[]
  notifications       Notification[]
  apiLogs             ApiLog[]
  backgroundJobs      BackgroundJob[]
  syncRuns            SyncRun[]
  exportRuns          ExportRun[]
  subscription        Subscription?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  plan                 BillingPlan        @default(FREE)
  interval             BillingInterval    @default(MONTHLY)
  status               SubscriptionStatus @default(FREE)
  provider             String             @default("paypal")
  paypalSubscriptionId String?            @unique
  paypalPlanId         String?
  payerEmail           String?
  currentPeriodEnd     DateTime?
  lastPaymentAt        DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([paypalPlanId])
}

model PricingPlan {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  audience      String
  monthlyPrice  Decimal? @db.Decimal(10, 2)
  summary       String   @db.Text
  idealFor      String   @db.Text
  quickFeatures Json
  exclusions    Json
  isFeatured    Boolean  @default(false)
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model PricingAddOn {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  category    String   @default("General")
  monthlyPrice Decimal  @default(0) @db.Decimal(10, 2)
  description String   @db.Text
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, sortOrder])
  @@index([category])
}

model PayPalWebhookEvent {
  id            String   @id @default(cuid())
  paypalEventId String   @unique
  eventType     String
  resourceId    String?
  receivedAt    DateTime @default(now())

  @@index([eventType])
  @@index([resourceId])
}

model EncryptedVault {
  id            String   @id @default(cuid())
  userId        String
  name          String
  encryptedBlob String   @db.LongText
  salt          String
  iv            String
  kdf           String   @default("PBKDF2")
  iterations    Int      @default(250000)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
}

model Organization {
  id                  String               @id @default(cuid())
  name                String
  slug                String               @unique
  ownerId             String
  plan                String               @default("free")
  monthlyContactLimit Int                  @default(10000)
  monthlyApiLimit     Int                  @default(50000)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  owner               User                 @relation("OrganizationOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members             OrganizationMember[]
  workspaces          Workspace[]

  @@index([ownerId])
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           TeamRole     @default(MEMBER)
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

model Workspace {
  id                  String               @id @default(cuid())
  organizationId      String
  name                String
  slug                String
  isDefault           Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contacts            Contact[]
  integrationAccounts IntegrationAccount[]
  syncRuns            SyncRun[]
  exportRuns          ExportRun[]
  automationRules     AutomationRule[]
  apiLogs             ApiLog[]
  backgroundJobs      BackgroundJob[]

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model SavedEmailAccount {
  id                String       @id @default(cuid())
  ownerId           String
  label             String
  email             String
  host              String
  port              Int
  security          SecurityType
  username          String
  encryptedPassword String
  encryptionIv      String
  encryptionTag     String
  isDefault         Boolean      @default(false)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  owner             User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, label])
  @@index([ownerId])
}

model IgnoredEmail {
  id        String   @id @default(cuid())
  ownerId   String
  email     String
  createdAt DateTime @default(now())
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, email])
  @@index([ownerId])
}

model KitSettings {
  id                  String            @id @default(cuid())
  ownerId             String            @unique
  apiVersion          KitApiVersion     @default(v4)
  encryptedApiKey     String
  encryptedApiSecret  String?
  encryptionIv        String
  encryptionTag       String
  secretEncryptionIv  String?
  secretEncryptionTag String?
  defaultTagId        String?
  defaultFormId       String?
  folderTagMappings   KitFolderTagMap[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  owner               User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

model KitFolderTagMap {
  id            String      @id @default(cuid())
  kitSettingsId String
  folderPath    String
  tagId         String
  tagName       String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  kitSettings   KitSettings @relation(fields: [kitSettingsId], references: [id], onDelete: Cascade)

  @@unique([kitSettingsId, folderPath])
  @@index([kitSettingsId])
}

model KitAccount {
  id                  String        @id @default(cuid())
  ownerId             String
  name                String
  apiVersion          KitApiVersion @default(v4)
  encryptedApiKey     String
  encryptedApiSecret  String?
  encryptionIv        String
  encryptionTag       String
  secretEncryptionIv  String?
  secretEncryptionTag String?
  isDefault           Boolean       @default(false)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  owner               User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, name])
  @@index([ownerId])
}

model Contact {
  id                  String                 @id @default(cuid())
  ownerId             String
  workspaceId         String?
  email               String
  normalizedEmail     String
  name                String?
  company             String?
  domain              String?
  emailClassification EmailClassification    @default(UNKNOWN)
  sourceType          ContactSourceType      @default(DIRECT_EMAIL)
  sourceFolder        String?                @db.Text
  forwardedBy         String?
  originalSender      String?
  duplicateScore      Int                    @default(0)
  leadScore           Int                    @default(0)
  status              ContactStatus          @default(NEW)
  starred             Boolean                @default(false)
  firstSeenAt         DateTime?
  lastSeenAt          DateTime?
  emailCount          Int                    @default(1)
  aiCategory          String?
  aiSummary           String?
  aiConfidence        Float?
  metadata            Json?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  owner               User                   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  workspace           Workspace?             @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  notes               ContactNote[]
  tags                ContactTagAssignment[]
  activities          ContactActivity[]

  @@unique([ownerId, normalizedEmail])
  @@index([ownerId, domain])
  @@index([ownerId, createdAt])
  @@index([ownerId, updatedAt])
  @@index([ownerId, lastSeenAt])
  @@index([ownerId, status])
  @@index([email])
  @@index([workspaceId])
  @@index([status])
}

model ContactNote {
  id        String   @id @default(cuid())
  contactId String
  authorId  String?
  body      String
  createdAt DateTime @default(now())
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
}

model ContactTag {
  id          String                 @id @default(cuid())
  ownerId     String
  name        String
  color       String?
  description String?
  createdAt   DateTime               @default(now())
  assignments ContactTagAssignment[]

  @@unique([ownerId, name])
  @@index([ownerId])
}

model ContactTagAssignment {
  id        String     @id @default(cuid())
  contactId String
  tagId     String
  createdAt DateTime   @default(now())
  contact   Contact    @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag       ContactTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([contactId, tagId])
  @@index([tagId])
}

model ContactActivity {
  id        String   @id @default(cuid())
  contactId String
  type      String
  title     String
  detail    String?
  metadata  Json?
  createdAt DateTime @default(now())
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([type])
}

model IntegrationAccount {
  id                  String                   @id @default(cuid())
  ownerId             String
  workspaceId         String?
  platform            MarketingPlatform
  name                String
  encryptedApiKey     String
  encryptedApiSecret  String?
  encryptionIv        String
  encryptionTag       String
  secretEncryptionIv  String?
  secretEncryptionTag String?
  isDefault           Boolean                  @default(false)
  health              IntegrationHealth        @default(UNKNOWN)
  lastTestedAt        DateTime?
  lastSyncedAt        DateTime?
  rateLimitRemaining  Int?
  externalAccountId   String?
  metadata            Json?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  owner               User                     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  workspace           Workspace?               @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  destinations        IntegrationDestination[]
  syncRuns            SyncRun[]
  exportRuns          ExportRun[]

  @@unique([ownerId, platform, name])
  @@index([ownerId, platform])
  @@index([platform, createdAt])
  @@index([workspaceId])
}

model IntegrationDestination {
  id                   String             @id @default(cuid())
  integrationAccountId String
  externalId           String
  name                 String
  type                 String
  contactCount         Int?
  metadata             Json?
  updatedAt            DateTime           @updatedAt
  integrationAccount   IntegrationAccount @relation(fields: [integrationAccountId], references: [id], onDelete: Cascade)

  @@unique([integrationAccountId, externalId, type])
  @@index([integrationAccountId])
}

model SyncRun {
  id                   String              @id @default(cuid())
  ownerId              String?
  workspaceId          String?
  integrationAccountId String?
  jobId                String?             @unique
  platform             MarketingPlatform?
  status               SyncStatus          @default(QUEUED)
  targetType           String?
  targetId             String?
  targetName           String?             @db.Text
  currentFolder        String?             @db.Text
  totalMessages        Int                 @default(0)
  processedMessages    Int                 @default(0)
  contactsFound        Int                 @default(0)
  duplicatesRemoved    Int                 @default(0)
  cancelRequested      Boolean             @default(false)
  totalContacts        Int                 @default(0)
  uploaded             Int                 @default(0)
  updated              Int                 @default(0)
  skippedDuplicates    Int                 @default(0)
  failed               Int                 @default(0)
  startedAt            DateTime?
  completedAt          DateTime?
  finishedAt           DateTime?
  errorMessage         String?             @db.Text
  metadata             Json?
  createdAt            DateTime            @default(now())
  owner                User?               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  workspace            Workspace?          @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  integrationAccount   IntegrationAccount? @relation(fields: [integrationAccountId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([ownerId, createdAt])
  @@index([integrationAccountId])
  @@index([platform, createdAt])
  @@index([status])
  @@index([jobId])
}

model ExportRun {
  id                   String              @id @default(cuid())
  ownerId              String?
  workspaceId          String?
  integrationAccountId String?
  format               ExportFormat
  status               SyncStatus          @default(QUEUED)
  fileName             String?
  totalContacts        Int                 @default(0)
  exportedContacts     Int                 @default(0)
  failedContacts       Int                 @default(0)
  filterSnapshot       Json?
  createdAt            DateTime            @default(now())
  completedAt          DateTime?
  errorMessage         String?             @db.Text
  owner                User?               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  workspace            Workspace?          @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  integrationAccount   IntegrationAccount? @relation(fields: [integrationAccountId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([ownerId, createdAt])
  @@index([createdAt])
  @@index([format])
}

model DuplicateCleanupLog {
  id               String   @id @default(cuid())
  ownerId          String
  workspaceId      String?
  duplicateEmail   String
  duplicateCount   Int
  winningContactId String?
  strategy         String
  confidence       Int      @default(0)
  metadata         Json?
  createdAt        DateTime @default(now())

  @@index([ownerId, createdAt])
  @@index([workspaceId])
}

model ApiLog {
  id          String             @id @default(cuid())
  ownerId     String?
  workspaceId String?
  platform    MarketingPlatform?
  action      String
  statusCode  Int?
  status      String
  durationMs  Int?
  requestId   String?
  message     String?
  metadata    Json?
  createdAt   DateTime           @default(now())
  owner       User?              @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  workspace   Workspace?         @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([ownerId, createdAt])
  @@index([workspaceId, createdAt])
  @@index([platform])
}

model Notification {
  id        String    @id @default(cuid())
  ownerId   String
  type      String
  title     String
  body      String?
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime  @default(now())
  owner     User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId, readAt])
}

model AutomationRule {
  id          String            @id @default(cuid())
  ownerId     String
  workspaceId String?
  name        String
  trigger     AutomationTrigger
  enabled     Boolean           @default(true)
  schedule    String?
  conditions  Json?
  actions     Json?
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  owner       User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  workspace   Workspace?        @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([ownerId, enabled])
  @@index([workspaceId])
}

model BackgroundJob {
  id          String     @id @default(cuid())
  ownerId     String?
  workspaceId String?
  type        JobType
  status      JobStatus  @default(QUEUED)
  attempts    Int        @default(0)
  maxAttempts Int        @default(3)
  runAfter    DateTime   @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  payload     Json?
  result      Json?
  error       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  owner       User?      @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([status, runAfter])
  @@index([ownerId])
  @@index([workspaceId])
}
