generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum SecurityType {
  ssl_tls
  starttls
}

enum KitApiVersion {
  v4
  v3
}

model User {
  id            String             @id @default(cuid())
  name          String
  email         String             @unique
  passwordHash  String
  role          UserRole           @default(USER)
  savedAccounts SavedEmailAccount[]
  ignoredEmails IgnoredEmail[]
  kitSettings   KitSettings?
  kitAccounts   KitAccount[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model SavedEmailAccount {
  id                String       @id @default(cuid())
  ownerId           String
  label             String
  email             String
  host              String
  port              Int
  security          SecurityType
  username          String
  encryptedPassword String
  encryptionIv      String
  encryptionTag     String
  isDefault         Boolean      @default(false)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  owner             User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@unique([ownerId, label])
}

model IgnoredEmail {
  id        String   @id @default(cuid())
  ownerId   String
  email     String
  createdAt DateTime @default(now())
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@unique([ownerId, email])
}

model KitSettings {
  id                 String             @id @default(cuid())
  ownerId            String             @unique
  apiVersion         KitApiVersion      @default(v4)
  encryptedApiKey    String
  encryptedApiSecret String?
  encryptionIv       String
  encryptionTag      String
  secretEncryptionIv String?
  secretEncryptionTag String?
  defaultTagId       String?
  defaultFormId      String?
  folderTagMappings  KitFolderTagMap[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  owner              User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

model KitFolderTagMap {
  id            String      @id @default(cuid())
  kitSettingsId String
  folderPath    String
  tagId         String
  tagName       String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  kitSettings   KitSettings @relation(fields: [kitSettingsId], references: [id], onDelete: Cascade)

  @@unique([kitSettingsId, folderPath])
  @@index([kitSettingsId])
}

model KitAccount {
  id                  String        @id @default(cuid())
  ownerId             String
  name                String
  apiVersion          KitApiVersion @default(v4)
  encryptedApiKey     String
  encryptedApiSecret  String?
  encryptionIv        String
  encryptionTag       String
  secretEncryptionIv  String?
  secretEncryptionTag String?
  isDefault           Boolean       @default(false)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  owner               User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@unique([ownerId, name])
}
